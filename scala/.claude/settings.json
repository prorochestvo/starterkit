{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(sbt:*)",
      "Bash(sbt compile:*)",
      "Bash(sbt test:*)",
      "Bash(sbt testOnly:*)",
      "Bash(sbt run:*)",
      "Bash(sbt clean:*)",
      "Bash(sbt update:*)",
      "Bash(sbt console:*)",
      "Bash(sbt reload:*)",
      "Bash(sbt scalafmtAll:*)",
      "Bash(sbt scalafmtCheckAll:*)",
      "Bash(sbt scalafmtSbt:*)",
      "Bash(sbt scalafixAll:*)",
      "Bash(sbt dependencyTree:*)",
      "Bash(scalafmt:*)",
      "Bash(scala-cli:*)",
      "Bash(coursier:*)",
      "Bash(cs:*)",
      "Bash(mill:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git restore:*)",
      "Bash(git mv:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git checkout:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(*.env)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Edit(*.env)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Write(*.env)",
      "Read(**/.idea/**)",
      "Edit(**/.idea/**)",
      "Write(**/.idea/**)",
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)"
    ]
  }
}
