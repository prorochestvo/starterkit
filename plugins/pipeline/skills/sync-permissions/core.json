{
  "allow": [
    "Bash(grep:*)",
    "Bash(rg:*)",
    "Bash(find:*)",
    "Bash(ls:*)",
    "Bash(cat:*)",
    "Bash(head:*)",
    "Bash(tail:*)",
    "Bash(wc:*)",
    "Bash(sed -n:*)",
    "Bash(awk:*)",
    "Bash(diff:*)",
    "Bash(sort:*)",
    "Bash(uniq:*)",
    "Bash(git status:*)",
    "Bash(git diff:*)",
    "Bash(git log:*)",
    "Bash(git show:*)",
    "Bash(git add:*)",
    "Bash(git commit:*)",
    "Bash(git restore:*)",
    "Bash(git mv:*)",
    "Bash(git branch:*)",
    "Bash(git switch:*)",
    "Bash(git stash:*)",
    "Bash(git push:*)",
    "Bash(mkdir:*)",
    "Bash(mv:*)",
    "Bash(cp:*)",
    "Bash(touch:*)"
  ],
  "deny": [
    "Read(**/.env)",
    "Read(**/.env.*)",
    "Read(*.env)",
    "Edit(**/.env)",
    "Edit(**/.env.*)",
    "Edit(*.env)",
    "Write(**/.env)",
    "Write(**/.env.*)",
    "Write(*.env)",
    "Read(**/.idea/**)",
    "Edit(**/.idea/**)",
    "Write(**/.idea/**)",
    "Bash(rm -rf:*)",
    "Bash(git push --force:*)",
    "Bash(git push -f:*)",
    "Bash(git reset --hard:*)"
  ]
}
